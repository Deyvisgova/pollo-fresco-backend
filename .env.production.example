APP_NAME="Pollo Fresco"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.example.com
FRONTEND_URL=https://app.example.com
FORCE_HTTPS=true
TRUSTED_HOSTS=api.example.com
TRUSTED_PROXIES=*
CORS_ALLOWED_ORIGINS=https://app.example.com
SANCTUM_TOKEN_EXPIRATION=480

LOG_CHANNEL=daily
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pollo_fresco
DB_USERNAME=pollo_fresco_app
DB_PASSWORD=CAMBIAR_POR_UN_SECRETO_LARGO

CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_ENCRYPT=true
SESSION_SAME_SITE=lax

BACKUP_DIRECTORY=backups/base-datos
BACKUP_OFFSITE_DISK=s3
BACKUP_OFFSITE_DIRECTORY=pollo-fresco/base-datos
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="Pollo Fresco"

APIPERU_TOKEN=
SUNAT_AMBIENTE=beta
